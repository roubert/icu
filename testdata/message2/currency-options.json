      "exp": "€42.80"
    },
    {
      "src": "{42.74 :currency currency=EUR roundingIncrement=10 roundingMode=halfCeil}",
      "exp": "€42.70"
    },
    {
      "src": "{42.74 :currency currency=EUR roundingIncrement=10 roundingMode=ceil}",
      "exp": "€42.80"
    },
    {
      "src": "{42.75 :currency currency=EUR roundingIncrement=10 roundingMode=trunc}",
