      "exp": "€42.75"
    },
    {
      "src": "{-42.74 :currency currency=EUR roundingIncrement=5 roundingMode=halfEven}",
      "exp": "-€42.75"
    },
    {
      "src": "{-42.725 :currency currency=EUR roundingIncrement=5 roundingMode=halfEven}",
