    {
      "src": "{-42.77 :currency currency=EUR roundingIncrement=10 roundingMode=halfExpand}",
      "exp": "-€42.80"
    },
    {
      "src": "{42.74 :currency currency=EUR roundingIncrement=10 roundingMode=halfTrunc}",
      "exp": "€42.70"
    },
    {
      "src": "{42.75 :currency currency=EUR roundingIncrement=10 roundingMode=halfTrunc}",
      "exp": "€42.70"
    },
    {
      "src": "{42.77 :currency currency=EUR roundingIncrement=10 roundingMode=halfTrunc}",
      "exp": "€42.80"
    },
    {
      "src": "{-42.74 :currency currency=EUR roundingIncrement=10 roundingMode=halfTrunc}",
      "exp": "-€42.70"
    },
    {
      "src": "{-42.75 :currency currency=EUR roundingIncrement=10 roundingMode=halfTrunc}",
      "exp": "-€42.70"
    },
    {
      "src": "{-42.77 :currency currency=EUR roundingIncrement=10 roundingMode=halfTrunc}",
      "exp": "-€42.80"
    },
    {
      "src": "{42.74 :currency currency=EUR roundingIncrement=10 roundingMode=halfTrunc}",
      "exp": "€42.70"
