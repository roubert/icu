    },
    {
      "src": "{42.75 :currency currency=EUR roundingIncrement=2 fractionDigits=1}",
      "exp": "€42.76",
      "comment": "Result should be €42.8 -- see ICU-23433"
    },
    {
      "src": "{42.75 :currency currency=XOF roundingIncrement=2 fractionDigits=1}",
