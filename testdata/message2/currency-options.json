    },
    {
      "src": "{42.75 :currency currency=EUR roundingPriority=morePrecision}",
      "exp": "€42.75"
    },
    {
      "src": "{42.75 :currency currency=EUR roundingPriority=lessPrecision}",
      "exp": "€42.75"
    },
    {
      "src": "{42.75 :currency currency=EUR roundingIncrement=2}",
      "exp": "€42.76"
    },
    {
